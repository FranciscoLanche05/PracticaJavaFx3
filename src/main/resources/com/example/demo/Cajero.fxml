<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="620.0"
            styleClass="bg-light" stylesheets="@bootstrap.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.demo.CajeroController">
    <children>
        <VBox spacing="20.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- Navbar superior -->
            <HBox alignment="CENTER_LEFT" styleClass="navbar" spacing="12">
                <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>
                <Label text="🏦" styleClass="navbar-brand-icon"/>
                <Label text="Sistema Bancario" styleClass="navbar-brand"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Cajero" styleClass="badge-role"/>
                <Button fx:id="btnLogout" onAction="#cerrarSesion"
                        text="⬅ Salir" styleClass="btn-logout"/>
            </HBox>
            <Label fx:id="lblError" styleClass="error-bar" maxWidth="Infinity" text=""/>

            <!-- Contenido principal -->
            <VBox spacing="20.0" VBox.vgrow="ALWAYS">
                <padding><Insets top="10" right="30" bottom="20" left="30"/></padding>

                <VBox styleClass="card" spacing="6">
                    <Label styleClass="title, text-success" text="Panel de Cajero"/>
                    <Label styleClass="text-muted" text="Bienvenido al módulo de operaciones de caja"/>
                </VBox>

                <HBox spacing="16">
                    <VBox styleClass="card-action" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="💵" styleClass="card-icon"/>
                        <Label text="Depósitos" styleClass="subtitle"/>
                        <Label text="Registrar depósitos de clientes" styleClass="text-muted-sm"/>
                        <Button text="Acceder" styleClass="btn, btn-success" maxWidth="Infinity"/>
                    </VBox>
                    <VBox styleClass="card-action" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="🏧" styleClass="card-icon"/>
                        <Label text="Retiros" styleClass="subtitle"/>
                        <Label text="Gestionar retiros de cuentas" styleClass="text-muted-sm"/>
                        <Button text="Acceder" styleClass="btn, btn-primary" maxWidth="Infinity"/>
                    </VBox>
                    <VBox styleClass="card-action" spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="🔄" styleClass="card-icon"/>
                        <Label text="Transferencias" styleClass="subtitle"/>
                        <Label text="Enviar fondos entre cuentas" styleClass="text-muted-sm"/>
                        <Button text="Acceder" styleClass="btn, btn-danger" maxWidth="Infinity"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>